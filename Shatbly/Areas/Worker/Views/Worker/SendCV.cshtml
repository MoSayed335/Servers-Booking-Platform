@model WorkerVM


    <title>Shtbly | شطبلي - تقديم كفنى</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Cairo', sans-serif; background-color: #f8f9fa; }
        .hero-section {
            background: linear-gradient(rgba(10, 38, 71, 0.85), rgba(10, 38, 71, 0.85)),
                        url('https://images.unsplash.com/photo-1581094794329-c8112a89af12?q=80&w=2070');
            background-size: cover;
            padding: 80px 0 140px;
            color: white;
            text-align: center;
        }
        .auth-card { border: none; border-radius: 25px; overflow: hidden; }
        .password-strength-bar { height: 5px; border-radius: 5px; transition: all 0.3s; }
    </style>


<section class="container" style="margin-top: -60px;">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card auth-card shadow-lg p-4 p-md-5">

            

                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle mb-3" style="width:70px;height:70px;font-size:2rem;">
                        <i class="bi bi-person-plus-fill"></i>
                    </div>
                    <h2 class="fw-bold mb-1">إنشاء حساب جديد</h2>
                    <p class="text-muted small">أدخل بياناتك لإنشاء حسابك على شطبلي</p>
                </div>

                <form asp-action="SendCV" method ="post"  enctype="multipart/form-data">
                                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <!-- Name Row -->
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label  asp-for="FName"class="form-label fw-bold">الاسم الأول</label>
                            <div class="input-group">
                                <input asp-for="FName" class="form-control border-start-0 ps-0" id="firstName" name="firstName"
                                       placeholder="محمد" required minlength="2" autocomplete="given-name">
                                 <span asp-validation-for="FName" class="text-danger"></span>

                                <div class="invalid-feedback">أدخل الاسم الأول (حرفان على الأقل).</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LName" class="form-label fw-bold">الاسم الأخير</label>
                            <div class="input-group">
                              
                                <input asp-for="LName" type="text" class="form-control border-start-0 ps-0" id="lastName" name="lastName"
                                       placeholder="أحمد" required minlength="2" autocomplete="family-name">
                                <span asp-validation-for="LName" class="text-danger"></span>

                                <div class="invalid-feedback">أدخل الاسم الأخير (حرفان على الأقل).</div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label  asp-for="Email" class="form-label fw-bold">البريد الإلكتروني</label>
                        <div class="input-group">
                            <input  asp-for="Email" type="email" class="form-control border-start-0 ps-0" id="email" name="email"
                                   placeholder="example@mail.com" required autocomplete="email">
                                                   <span asp-validation-for="Email" class="text-danger"></span>

                            <div class="invalid-feedback">أدخل بريداً إلكترونياً صحيحاً.</div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label fw-bold">رقم الهاتف</label>
                        <div class="input-group">
                            
                            <input asp-for="Phone" type="tel" class="form-control border-start-0 ps-0" id="phone" name="phone"
                                   placeholder="01xxxxxxxxx" required pattern="^(01)[0-9]{9}$" autocomplete="tel">
                                                   <span asp-validation-for="Phone" class="text-danger"></span>

                            <div class="invalid-feedback">أدخل رقم هاتف مصري صحيح (01xxxxxxxxx).</div>
                        </div>
                    </div>    
                     <div class="mb-3">
                    <label asp-for="cv" class="form-label fw-bold">CV</label>
                     <div class="input-group">
                    <input asp-for="cv" type="file" class="form-control" id="Logo" placeholder="Enter brand logo" name="logo" multiple>
                    <span asp-validation-for="cv" class="text-danger"></span>
                        <div class="invalid-feedback">ارسل السيره الذاتيه</div>
                        </div>
                </div>
                </form>
            </div>
        </div>
    </div>
</section>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

@section Scripts {
    <partial name="~/Views/Shared/_NotificationPartial.cshtml" />
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
}