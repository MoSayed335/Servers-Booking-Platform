@model ForgetPasswordVM

    <title>Shtbly | شطبلي - نسيت كلمة المرور</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Cairo', sans-serif; background-color: #f8f9fa; }
        .hero-section {
            background: linear-gradient(rgba(10, 38, 71, 0.85), rgba(10, 38, 71, 0.85)),
                        url('https://images.unsplash.com/photo-1581094794329-c8112a89af12?q=80&w=2070');
            background-size: cover;
            padding: 100px 0 160px;
            color: white;
            text-align: center;
        }
        .auth-card { border: none; border-radius: 25px; overflow: hidden; }
    </style>



<section class="container" style="margin-top: -80px;">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card auth-card shadow-lg p-4 p-md-5">

          
                    <p class="mb-0 small">إذا كان الحساب موجوداً، ستصلك رسالة بريد إلكتروني تحتوي على رابط إعادة تعيين كلمة المرور خلال دقائق.</p>
                </div>

                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center bg-warning bg-opacity-10 text-warning rounded-circle mb-3" style="width:70px;height:70px;font-size:2rem;">
                        <i class="bi bi-key-fill"></i>
                    </div>
                    <h2 class="fw-bold mb-1">نسيت كلمة المرور؟</h2>
                    <p class="text-muted small">أدخل بريدك الإلكتروني أو اسم المستخدم وسنرسل لك رابط إعادة التعيين.</p>
                </div>

                <form asp-action="ForgetPassword">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="mb-4">
                        <label asp-for="EmailOrUserName" class="form-label fw-bold">البريد الإلكتروني أو اسم المستخدم</label>
                        <div class="input-group">
                            <input type="text" asp-for="EmailOrUserName" class="form-control border-start-0 ps-0"
                                   placeholder="example@mail.com أو username123" required autocomplete="email username">
                                     <span asp-validation-for="EmailOrUserName" class="text-danger"></span>
                            <div class="invalid-feedback">هذا الحقل مطلوب.</div>
                        </div>
                    </div>

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-warning fw-bold py-2 text-dark" style="border-radius:12px;">
                            <i class="bi bi-send me-1"></i> إرسال رابط الاسترداد
                        </button>
                    </div>

                    <div class="text-center">
                        <a asp-action="Login"  class="small text-primary text-decoration-none fw-bold">
                            <i class="bi bi-arrow-right me-1"></i> العودة إلى تسجيل الدخول
                        </a>
                    </div>
                </form>

                <!-- Help section -->
                <hr class="my-4 opacity-25">
                <div class="bg-light rounded-3 p-3">
                    <p class="small fw-bold mb-2 text-dark"><i class="bi bi-info-circle text-primary me-1"></i> لم تستلم البريد؟</p>
                    <ul class="small text-muted mb-2 ps-3">
                        <li>تحقق من مجلد الرسائل غير المرغوب فيها (Spam).</li>
                        <li>تأكد أنك أدخلت البريد الصحيح المرتبط بحسابك.</li>
                    </ul>
                    <a href="/Account/ResendEmailConfirmation" class="small text-primary text-decoration-none">إعادة إرسال بريد التأكيد</a>
                </div>
            </div>
        </div>
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.getElementById('forgotForm').addEventListener('submit', function(e) {
        e.preventDefault();
        if (!this.checkValidity()) { this.classList.add('was-validated'); return; }
        // Show success on valid submit (demo)
        document.getElementById('successAlert').classList.remove('d-none');
        this.style.opacity = '0.5';
        this.querySelectorAll('input,button').forEach(el => el.disabled = true);
    });
</script>

