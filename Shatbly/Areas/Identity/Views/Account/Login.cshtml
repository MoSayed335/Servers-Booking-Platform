@model LoginVM

    <title>Shtbly | شطبلي - تسجيل الدخول</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;800&display=swap" rel="stylesheet">
    <style>
            body {

                font-family: 'Cairo', sans-serif;
                background-color: #f8f9fa;
            }
            .hero-section {
                background: linear-gradient(rgba(10, 38, 71, 0.85), rgba(10, 38, 71, 0.85)), url('https://images.unsplash.com/photo-1581094794329-c8112a89af12?q=80&w=2070');
                background-size: cover;
                padding: 100px 0 160px;
                color: white;
                text-align: center;
            }

            .auth-card {
                border: none;
                border-radius: 25px;
                overflow: hidden;
            }
    </style>




    <section class="container" style="margin-top: -80px;">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card auth-card shadow-lg p-4 p-md-5">

            

                    <div class="text-center mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle mb-3" style="width:70px;height:70px;font-size:2rem;">
                            <i class="bi bi-person-check-fill"></i>
                        </div>
                        <h2 class="fw-bold mb-1">تسجيل الدخول</h2>
                        <p class="text-muted small">أدخل بياناتك للوصول إلى حسابك</p>
                    </div>

                <form asp-action="Login">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                        <label asp-for="EmailOrUserName" class="form-label fw-bold">البريد الإلكتروني أو اسم المستخدم</label>
                            <div class="input-group">
                            <input type="text" asp-for="EmailOrUserName" class="form-control border-start-0 ps-0" id="emailOrUsername" name="emailOrUsername"
                                       placeholder="example@mail.com أو username123" required autocomplete="username">\
                            <span asp-validation-for="EmailOrUserName" class="text-danger"></span>
                                <div class="invalid-feedback">هذا الحقل مطلوب.</div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                            <label asp-for="Password" class="form-label fw-bold mb-0">كلمة المرور</label>
                            <a asp-action ="ForgetPassword" class="small text-primary text-decoration-none">نسيت كلمة المرور؟</a>
                            </div>
                            <div class="input-group">
                            <span asp-validation-for="Password" class="text-danger"></span>

                            <input asp-for="Password" class="form-control border-start-0 ps-0"
                                       placeholder="أدخل كلمة المرور" required autocomplete="current-password">
                                <button class="btn btn-outline-secondary border-start-0" type="button" id="togglePassword" tabindex="-1" aria-label="إظهار/إخفاء كلمة المرور">
                                    <i class="bi bi-eye" id="eyeIcon"></i>
                                </button>
                                <div class="invalid-feedback">كلمة المرور مطلوبة.</div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="form-check">
                            <input class="form-check-input" asp-for="RememberMe" /> @Html.DisplayNameFor(model => model.RememberMe)
                                <label class="form-check-label" for="rememberMe" >تذكّرني</label>
                            </div>
                        </div>

                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-primary fw-bold py-2" style="border-radius:12px;">
                                <i class="bi bi-box-arrow-in-right me-1"></i> تسجيل الدخول
                            </button>
                        </div>

                        <div class="text-center">
                            <span class="text-muted small">ليس لديك حساب؟ </span>
                        <a asp-action ="Register" class="small text-primary fw-bold text-decoration-none">سجّل الآن</a>
                        </div>
                    <div class="text-center">
                        <span class="text-muted small"> إعادة إرسال بريد التأكيد</span>
                        <a asp-action="ResendEmailConfirmation" class="small text-primary fw-bold text-decoration-none">سجّل الآن</a>
                    </div>
                    </form>
                </div>
            </div>
        </div>
    </section>

 
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('togglePassword').addEventListener('click', function () {
        const pwd = document.getElementById('password');
        const icon = document.getElementById('eyeIcon');
        if (pwd.type === 'password') { pwd.type = 'text'; icon.classList.replace('bi-eye','bi-eye-slash'); }
        else { pwd.type = 'password'; icon.classList.replace('bi-eye-slash','bi-eye'); }
        });
        document.getElementById('loginForm').addEventListener('submit', function(e) {
        e.preventDefault();
        if (!this.checkValidity()) { this.classList.add('was-validated'); return; }
        // TODO: submit logic
        });
    </script>

