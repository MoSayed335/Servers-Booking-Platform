
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shtbly | شطبلي - إعادة تعيين كلمة المرور</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Cairo', sans-serif; background-color: #f8f9fa; }
        .hero-section {
            background: linear-gradient(rgba(10, 38, 71, 0.85), rgba(10, 38, 71, 0.85)),
                        url('https://images.unsplash.com/photo-1581094794329-c8112a89af12?q=80&w=2070');
            background-size: cover;
            padding: 100px 0 160px;
            color: white;
            text-align: center;
        }
        .auth-card { border: none; border-radius: 25px; overflow: hidden; }
    </style>


<section class="container" style="margin-top: -80px;">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
          
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center bg-success bg-opacity-10 text-success rounded-circle mb-3" style="width:70px;height:70px;font-size:2rem;">
                        <i class="bi bi-shield-lock-fill"></i>
                    </div>
                    <h2 class="fw-bold mb-1">تعيين كلمة مرور جديدة</h2>
                    <p class="text-muted small">اختر كلمة مرور قوية لحماية حسابك.</p>
                </div>

                <form novalidate id="resetForm">
                    <!-- Hidden UserId field -->
                    <input type="hidden" id="userId" name="userId" value="">
                    <!-- Hidden Token field (usually from URL) -->
                    <input type="hidden" id="token" name="token" value="">

                    <div class="mb-3">
                        <label for="newPassword" class="form-label fw-bold">كلمة المرور الجديدة</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-lock text-success"></i>
                            </span>
                            <input type="password" class="form-control border-start-0 ps-0" id="newPassword" name="newPassword"
                                   placeholder="8 أحرف على الأقل" required minlength="8" autocomplete="new-password">
                            <button class="btn btn-outline-secondary border-start-0" type="button" id="toggleNew" tabindex="-1" aria-label="إظهار/إخفاء">
                                <i class="bi bi-eye" id="eyeNew"></i>
                            </button>
                            <div class="invalid-feedback">كلمة المرور يجب أن تكون 8 أحرف على الأقل.</div>
                        </div>
                        <!-- Strength bar -->
                        <div class="mt-2">
                            <div class="progress" style="height:5px;border-radius:5px;">
                                <div class="progress-bar" id="strengthBar" role="progressbar" style="width:0%" aria-label="قوة كلمة المرور"></div>
                            </div>
                            <small id="strengthText" class="text-muted"></small>
                        </div>
                    </div>

                    <!-- Password requirements checklist -->
                    <div class="bg-light rounded-3 p-3 mb-3">
                        <p class="small fw-bold mb-2 text-dark">متطلبات كلمة المرور:</p>
                        <ul class="list-unstyled mb-0 small">
                            <li id="req-length" class="text-muted mb-1"><i class="bi bi-circle me-1"></i> 8 أحرف على الأقل</li>
                            <li id="req-upper"  class="text-muted mb-1"><i class="bi bi-circle me-1"></i> حرف كبير واحد على الأقل (A-Z)</li>
                            <li id="req-number" class="text-muted mb-1"><i class="bi bi-circle me-1"></i> رقم واحد على الأقل (0-9)</li>
                            <li id="req-special" class="text-muted"><i class="bi bi-circle me-1"></i> رمز خاص واحد على الأقل (!#$...)</li>
                        </ul>
                    </div>

                    <div class="mb-4">
                        <label for="confirmPassword" class="form-label fw-bold">تأكيد كلمة المرور</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-lock-fill text-success"></i>
                            </span>
                            <input type="password" class="form-control border-start-0 ps-0" id="confirmPassword" name="confirmPassword"
                                   placeholder="أعد إدخال كلمة المرور الجديدة" required autocomplete="new-password">
                            <button class="btn btn-outline-secondary border-start-0" type="button" id="toggleConfirm" tabindex="-1" aria-label="إظهار/إخفاء">
                                <i class="bi bi-eye" id="eyeConfirm"></i>
                            </button>
                            <div class="invalid-feedback" id="confirmFeedback">يرجى تأكيد كلمة المرور الجديدة.</div>
                        </div>
                    </div>

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-success fw-bold py-2" style="border-radius:12px;">
                            <i class="bi bi-shield-check me-1"></i> تعيين كلمة المرور الجديدة
                        </button>
                    </div>

                    <div class="text-center">
                        <a href="/Account/Login" class="small text-primary text-decoration-none fw-bold">
                            <i class="bi bi-arrow-right me-1"></i> العودة إلى تسجيل الدخول
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<footer class="bg-dark text-white pt-5 pb-3 mt-5">
    <div class="container">
        <div class="row g-4 text-center text-md-end">
            <div class="col-md-4"><h3 class="fw-bold text-primary mb-3">SHTBLY</h3><p class="text-light opacity-75">المنصة الموثوقة لخدمات الصيانة والتشطيب في مصر.</p></div>
            <div class="col-md-4"><h5 class="fw-bold mb-3">روابط سريعة</h5><ul class="list-unstyled"><li class="mb-2"><a href="#" class="text-white text-decoration-none opacity-75">سياسة الخصوصية</a></li><li class="mb-2"><a href="#" class="text-white text-decoration-none opacity-75">الشروط والأحكام</a></li><li><a href="#" class="text-white text-decoration-none opacity-75">تواصل معنا</a></li></ul></div>
            <div class="col-md-4"><h5 class="fw-bold mb-3">تابعنا على</h5><div class="d-flex justify-content-center justify-content-md-start gap-3"><a href="#" class="text-white fs-3"><i class="bi bi-facebook"></i></a><a href="#" class="text-white fs-3"><i class="bi bi-instagram"></i></a><a href="#" class="text-white fs-3"><i class="bi bi-whatsapp"></i></a></div></div>
        </div>
        <hr class="mt-5 mb-4 border-secondary opacity-25">
        <div class="text-center"><p class="small text-light opacity-50 mb-0">&copy; 2026 Shtbly. جميع الحقوق محفوظة.</p></div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Populate hidden fields from URL params
    const params = new URLSearchParams(window.location.search);
    if (params.get('userId')) document.getElementById('userId').value = params.get('userId');
    if (params.get('token'))  document.getElementById('token').value  = params.get('token');

    function toggleVis(inputId, iconId) {
        const inp = document.getElementById(inputId);
        const ic  = document.getElementById(iconId);
        inp.type = inp.type === 'password' ? 'text' : 'password';
        ic.classList.toggle('bi-eye'); ic.classList.toggle('bi-eye-slash');
    }
    document.getElementById('toggleNew').addEventListener('click', () => toggleVis('newPassword','eyeNew'));
    document.getElementById('toggleConfirm').addEventListener('click', () => toggleVis('confirmPassword','eyeConfirm'));

    // Password strength + requirement checklist
    document.getElementById('newPassword').addEventListener('input', function() {
        const v = this.value;
        const checks = [
            { id:'req-length',  pass: v.length >= 8 },
            { id:'req-upper',   pass: /[A-Z]/.test(v) },
            { id:'req-number',  pass: /[0-9]/.test(v) },
            { id:'req-special', pass: /[^A-Za-z0-9]/.test(v) }
        ];
        checks.forEach(c => {
            const el = document.getElementById(c.id);
            const icon = el.querySelector('i');
            if (c.pass) {
                el.classList.replace('text-muted','text-success');
                icon.classList.replace('bi-circle','bi-check-circle-fill');
            } else {
                el.classList.replace('text-success','text-muted');
                icon.classList.replace('bi-check-circle-fill','bi-circle');
            }
        });
        const score = checks.filter(c=>c.pass).length;
        const bar = document.getElementById('strengthBar');
        const txt = document.getElementById('strengthText');
        const levels = [
            { pct:'25%', cls:'bg-danger', label:'ضعيفة جداً' },
            { pct:'50%', cls:'bg-warning', label:'ضعيفة' },
            { pct:'75%', cls:'bg-info',    label:'متوسطة' },
            { pct:'100%',cls:'bg-success', label:'قوية' }
        ];
        if (score === 0) { bar.style.width='0%'; txt.textContent=''; return; }
        const l = levels[score-1];
        bar.style.width = l.pct; bar.className = 'progress-bar '+l.cls;
        txt.textContent = 'قوة كلمة المرور: '+l.label;
        txt.className = 'small '+(score<3?'text-danger':score<4?'text-warning':'text-success');
    });

    document.getElementById('confirmPassword').addEventListener('input', function() {
        if (this.value === document.getElementById('newPassword').value) this.setCustomValidity('');
    });

    document.getElementById('resetForm').addEventListener('submit', function(e) {
        e.preventDefault();
        this.classList.add('was-validated');
        const pwd = document.getElementById('newPassword').value;
        const conf = document.getElementById('confirmPassword');
        if (pwd !== conf.value) {
            conf.setCustomValidity('لا تتطابق');
            document.getElementById('confirmFeedback').textContent = 'كلمتا المرور غير متطابقتين.';
            return;
        } else { conf.setCustomValidity(''); }
        if (!this.checkValidity()) return;
        // TODO: submit logic
    });
</script>

