@model Shatbly.ViewModels.BookingDetailsVM

@{
    ViewData["Title"] = "Booking Details";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Booking Details</h2>
            <p class="text-muted mb-0">Booking #@Model.Booking.Id</p>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Booking.Id" class="btn btn-warning text-white">
                <i class="fa-solid fa-pen-to-square me-1"></i> Edit
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fa-solid fa-arrow-left me-1"></i> Back
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Booking Info</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="text-muted small">Client</label>
                        <div class="fw-semibold">@Model.Booking.Client?.UserName</div>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted small">Worker Id</label>
                        <div class="fw-semibold">@Model.Booking.WorkerId</div>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted small">Address Id</label>
                        <div class="fw-semibold">@Model.Booking.AddressId</div>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted small">Scheduled At</label>
                        <div class="fw-semibold">@Model.Booking.ScheduledAt.ToString("yyyy-MM-dd hh:mm tt")</div>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted small">Duration</label>
                        <div class="fw-semibold">@Model.Booking.DurationHours hour(s)</div>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted small">Status</label>
                        <div>
                            <span class="badge bg-primary">@Model.Booking.Status</span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted small">Coupon</label>
                        <div class="fw-semibold">@(Model.Booking.Coupon?.Code ?? "No coupon")</div>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted small">Promo Code</label>
                        <div class="fw-semibold">@(Model.Booking.PromoCode?.Code ?? "No promo code")</div>
                    </div>

                    <div class="mb-0">
                        <label class="text-muted small">Created At</label>
                        <div class="fw-semibold">@Model.Booking.CreatedAt.ToString("yyyy-MM-dd hh:mm tt")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Booking Items</h5>
                    <span class="badge bg-dark">@Model.ItemCount Items</span>
                </div>

                <div class="card-body p-0">
                    @if (Model.Booking.BookingItems != null && Model.Booking.BookingItems.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>#</th>
                                        <th>Category</th>
                                        <th>Quantity</th>
                                        <th>Unit Price</th>
                                        <th>Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Booking.BookingItems)
                                    {
                                        <tr>
                                            <td>@item.Id</td>
                                            <td>@(item.Category?.ToString() ?? $"Category #{item.CategoryId}")</td>
                                            <td>@item.Quantity</td>
                                            <td>@item.UnitPrice.ToString("0.00")</td>
                                            <td>@((item.Quantity * item.UnitPrice).ToString("0.00"))</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            No booking items found.
                        </div>
                    }
                </div>

                @if (Model.Booking.BookingItems != null && Model.Booking.BookingItems.Any())
                {
                    <div class="card-footer bg-white">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Items Total</span>
                            <span class="fw-semibold">@Model.ItemsTotal.ToString("0.00")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Discount</span>
                            <span class="fw-semibold text-danger">- @Model.Booking.DiscountAmt.ToString("0.00")</span>
                        </div>
                        <div class="d-flex justify-content-between border-top pt-2">
                            <span class="fw-bold">Final Total</span>
                            <span class="fw-bold text-success">@Model.Booking.TotalPrice.ToString("0.00")</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>