@using Shatbly.ViewModels
@model WorkerServicesVM

@{
    ViewData["Title"] = "Edit Worker Service";
}

<div class="container-fluid">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <h3 class="mb-0">Edit Worker Service</h3>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input asp-for="Id" type="hidden" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="WorkerId" class="form-label"></label>
                        <select asp-for="WorkerId" class="form-select">
                            <option value="">-- Select Worker --</option>
                            @if (Model?.Workers is not null)
                            {
                                foreach (var worker in Model.Workers)
                                {
                                    <option value="@worker.Id" selected="@(worker.Id == Model.WorkerId)">@worker.User?.FName @worker.User?.LName</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="WorkerId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label"></label>
                        <select asp-for="CategoryId" class="form-select">
                            <option value="">-- Select Category --</option>
                            @if (Model?.Categories is not null)
                            {
                                foreach (var cat in Model.Categories)
                                {
                                    <option value="@cat.Id" selected="@(cat.Id == Model.CategoryId)">@cat.NameEn (@cat.NameAr)</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="HourlyRate" class="form-label"></label>
                        <input asp-for="HourlyRate" class="form-control" />
                        <span asp-validation-for="HourlyRate" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label"></label>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">Update</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_NotificationPartial" />
}
