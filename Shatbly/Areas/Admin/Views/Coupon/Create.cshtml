@model Coupon

@{
    ViewData["Title"] = "Create Coupon";
}

<div class="container-fluid">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <h3 class="mb-0">Create Coupon</h3>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Code" class="form-label"></label>
                        <input asp-for="Code" class="form-control" />
                        <span asp-validation-for="Code" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="DiscountValue" class="form-label"></label>
                        <input asp-for="DiscountValue" class="form-control" />
                        <span asp-validation-for="DiscountValue" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="DiscountType" class="form-label"></label>
                        <select asp-for="DiscountType" asp-items="Html.GetEnumSelectList<DiscountType>()" class="form-select">
                            <option value="">Select type</option>
                        </select>
                        <span asp-validation-for="DiscountType" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="MaxUses" class="form-label"></label>
                        <input asp-for="MaxUses" class="form-control" />
                        <span asp-validation-for="MaxUses" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ValidFrom" class="form-label"></label>
                        <input asp-for="ValidFrom" type="datetime-local" class="form-control" />
                        <span asp-validation-for="ValidFrom" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ValidUntil" class="form-label"></label>
                        <input asp-for="ValidUntil" type="datetime-local" class="form-control" />
                        <span asp-validation-for="ValidUntil" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label"></label>
                        <input asp-for="CategoryId" class="form-control" />
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label"></label>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_NotificationPartial" />
}