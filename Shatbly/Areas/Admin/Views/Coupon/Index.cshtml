@using System
@using System.Linq
@using System.Reflection
@model CouponsVM

@{
    ViewData["Title"] = "Coupons";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Coupons</h2>
            <p class="text-muted mb-0">Manage coupons, search by code, and remove unused items.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fa-solid fa-plus me-1"></i> Add Coupon
        </a>
    </div>

    <form asp-action="Index" method="get" class="row g-2 mb-4">
        <div class="col-md-4">
            <input type="text" name="coupon" value="@Context.Request.Query["coupon"]" class="form-control" placeholder="Search by coupon code" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-outline-primary">Search</button>
        </div>
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
        </div>
    </form>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Id</th>
                            <th>Code</th>
                            <th>Value</th>
                            <th>Type</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model?.Coupons is not null && Model.Coupons.Any())
                        {
                            foreach (var item in Model.Coupons)
                            {
                                <tr>
                                    <td>@GetValue(item, "Id")</td>
                                    <td>@GetValue(item, "Code")</td>
                                    <td>@GetValue(item, "Value", "DiscountValue", "DiscountAmount", "Amount")</td>
                                    <td>@GetValue(item, "Type", "DiscountType")</td>
                                    <td class="text-center">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning text-white">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>

                                        <button type="button"
                                                class="btn btn-sm btn-danger js-delete-coupon"
                                                data-id="@item.Id"
                                                data-code="@item.Code">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">No coupons found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (Model is not null && Model.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : null)">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-coupon="@Context.Request.Query["coupon"]">Previous</a>
                </li>

                @for (int i = 1; i <= Convert.ToInt32(Model.TotalPages); i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : null)">
                        <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-coupon="@Context.Request.Query["coupon"]">@i</a>
                    </li>
                }

                <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : null)">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-coupon="@Context.Request.Query["coupon"]">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>

@functions {
    public static object? GetValue(object source, params string[] propertyNames)
    {
        foreach (var propertyName in propertyNames)
        {
            var property = source.GetType().GetProperty(propertyName, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);
            if (property is not null)
            {
                return property.GetValue(source);
            }
        }

        return null;
    }
}

